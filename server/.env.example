# SHIKUM_API server configuration
# Copy to .env and adjust as needed.

# --- Database ---
# PostgreSQL connection string.
# For the bundled local portable cluster (npm run db:pg:start) use port 5544:
DATABASE_URL="postgresql://postgres:postgres@localhost:5544/shikum?schema=public"

# --- Server ---
PORT=3000

# Set to "production" in production deployments. Affects the CORS default below.
# NODE_ENV=production

# CORS allowed origins (comma-separated, or * for all).
# If UNSET: open in development, but cross-origin requests are BLOCKED in production
# (NODE_ENV=production) — the frontend is served from the same origin, so set this
# only to the external origins that must reach the API.
CORS_ORIGINS=*

# --- Delta sync safety ---
# Max share of active rows a single sync may soft-delete before it is refused
# (protects against uploading a partial file by mistake). Default 0.3 (30%).
# Override an intentional large deletion per-request with ?force=true on /apply.
# SYNC_MAX_DELETE_RATIO=0.3

# --- AI (Gemini) ---
# Optional: enable the AI chat assistant (RAG grounded in your data).
# Get a key at https://aistudio.google.com/app/apikey. Leave empty to use the
# free local search engine instead. Model can be overridden with GEMINI_MODEL.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# --- Admin ---
# Token required for admin endpoints (data reload, delta sync, config editing).
# Leave empty to DISABLE all admin endpoints.
ADMIN_TOKEN=shikum-admin-dev

# --- Data files (relative to server/data) ---
ITEMS_FILE=items_53331.xlsx
SUPPLIERS_FILE=suppliers_9028.xlsx
AGREEMENTS_FILE=agreements_52593.xlsx
GEO_MAPPING_FILE=geo_mapping.csv
