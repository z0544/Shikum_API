{
  "name": "shikum-api-server",
  "version": "1.6.0",
  "description": "SHIKUM_API backend (NestJS + Prisma)",
  "license": "MIT",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "prestart:prod": "prisma db push --skip-generate",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:setup": "prisma generate && prisma db push --skip-generate",
    "db:pg:start": "\"../.pg/pgsql/bin/pg_ctl.exe\" -D \"../.pg/data\" -l \"../.pg/pg.log\" -o \"-p 5544\" start",
    "db:pg:stop": "\"../.pg/pgsql/bin/pg_ctl.exe\" -D \"../.pg/data\" stop",
    "db:pg:status": "\"../.pg/pgsql/bin/pg_ctl.exe\" -D \"../.pg/data\" status",
    "etl": "ts-node -T src/etl/etl.cli.ts",
    "etl:prod": "node dist/etl/etl.cli.js",
    "providers:sync": "ts-node -T src/providers/providers.cli.ts",
    "providers:sync:prod": "node dist/providers/providers.cli.js",
    "db:deploy": "prisma db push --skip-generate && node dist/etl/etl.cli.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@prisma/client": "^5.20.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "prisma": "^5.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
